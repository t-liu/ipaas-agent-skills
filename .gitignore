# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.local
.env.*.local

# Testing & coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Ignore everything inside the backend directory
backend/*

# Exceptions: Do NOT ignore these
!backend/requirements.txt
!backend/app/

# ==========================================
# OpenTofu / Terraform Infrastructure
# ==========================================
# Local provider caches and binaries
infra/.terraform/

# Dynamic deployment zip bundles and files artifacts
infra/files/*.zip

# Local state tracking files (Crucial: Never commit these secrets/topology maps)
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfstate.*

# Ignored binary execution plans
infra/*.tfplan

# Local python environments hidden inside infra if used
infra/.venv/